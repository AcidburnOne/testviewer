+                    {VK_IMAGE_ASPECT_COLOR_BIT, level - 1, 0, 1},
+                    {{0, 0, 0}, {mip_width, mip_height, 1}},
+                    {VK_IMAGE_ASPECT_COLOR_BIT, level, 0, 1},
+                    {{0, 0, 0}, {next_width, next_height, 1}}};
