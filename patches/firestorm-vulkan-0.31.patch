+                {0, 0, 0}, {pending.width, pending.height, 1}};
+            vkCmdCopyBufferToImage(upload, staging.handle(), texture.image,
+                                   VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
