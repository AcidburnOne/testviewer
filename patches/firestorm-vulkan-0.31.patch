+    std::uint32_t image_index = 0;
+    status = vkAcquireNextImageKHR(
+        mImpl-&gt;device, mImpl-&gt;swapchain,
+        std::numeric_limits&lt;std::uint64_t&gt;::max(),
+        mImpl-&gt;image_available[frame], VK_NULL_HANDLE, &amp;image_index);
