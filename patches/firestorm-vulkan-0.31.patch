+
+LLVulkanFrameResult LLVulkanContext::drawValidationFrame(float red,
+                                                         float green,
+                                                         float blue)
+{
+#if !(FIRESTORM_VULKAN_EXPERIMENTAL &amp;&amp; LL_WINDOWS)
