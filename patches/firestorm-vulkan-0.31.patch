+        texture.width = pending.width;
+        texture.height = pending.height;
+        VkFormatProperties rgba8_properties{};
+        vkGetPhysicalDeviceFormatProperties(mImpl-&gt;physical_device,
+                                             VK_FORMAT_R8G8B8A8_UNORM,
+                                             &amp;rgba8_properties);
