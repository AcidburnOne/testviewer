+
+    const std::size_t frame = mImpl-&gt;current_frame;
+    VkResult status = vkWaitForFences(mImpl-&gt;device, 1,
+                                      &amp;mImpl-&gt;frame_fences[frame], VK_TRUE,
+                                      std::numeric_limits&lt;std::uint64_t&gt;::max());
