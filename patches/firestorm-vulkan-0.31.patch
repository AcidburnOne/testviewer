+                VK_STRUCTURE_TYPE_SUBMIT_INFO, nullptr, 0, nullptr, nullptr,
+                1, &amp;upload, 0, nullptr};
+            upload_status = vkQueueSubmit(mImpl-&gt;graphics_queue, 1,
+                                          &amp;submit, VK_NULL_HANDLE);
