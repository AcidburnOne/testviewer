+            probe_metadata.data(), metadata_bytes,
+            VK_BUFFER_USAGE_STORAGE_BUFFER_BIT,
+            mImpl-&gt;command_pool, mImpl-&gt;graphics_queue))
+    {
+        mImpl-&gt;error = "Unable to upload Vulkan probe metadata";
+        return LLVulkanFrameResult::ERROR;
+    }
